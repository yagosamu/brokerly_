DEBUG=False
SECRET_KEY=<django-secret-key>
DOMAIN=<your-domain>
ALLOWED_HOSTS=<your-domain>,.<your-domain>,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://<your-domain>,https://*.<your-domain>
DATABASE_URL=postgres://brokerly:<postgres-password>@db:5432/brokerly
POSTGRES_DB=brokerly
POSTGRES_USER=brokerly
POSTGRES_PASSWORD=<postgres-password>
CELERY_BROKER_URL=amqp://brokerly:<rabbitmq-password>@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1
CACHE_URL=redis://redis:6379/2
REDIS_URL=redis://redis:6379/0
RABBITMQ_DEFAULT_USER=brokerly
RABBITMQ_DEFAULT_PASS=<rabbitmq-password>
OPENAI_API_KEY=<openai-api-key>
OPENAI_MODEL=gpt-5.5-mini
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=<smtp-host>
EMAIL_PORT=587
EMAIL_HOST_USER=<smtp-user>
EMAIL_HOST_PASSWORD=<smtp-password>
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Brokerly <no-reply@your-domain>
TIME_ZONE=America/Sao_Paulo
LANGUAGE_CODE=pt-br
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
ACME_EMAIL=<acme-email>
TRAEFIK_DASHBOARD_AUTH=<traefik-dashboard-basic-auth>
CLOUDFLARE_DNS_API_TOKEN=<cloudflare-dns-api-token>
